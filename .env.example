# ─── FRIDAY API KEYS ─────────────────────────────────────────────
# Keep this file secret. Never commit it to git.
# Copy to .env and fill in your keys.

# Google Gemini (Brain & Vision)
GOOGLE_API_KEY=your_google_api_key_here
GCP_PROJECT=your_gcp_project
GCP_LOCATION=us-central1

# NVIDIA NIM (LLM + Vision)
NVIDIA_NIM_API_KEY=your_nvidia_nim_key_here

# Sarvam AI (Text-to-Speech)
SARVAM_API_KEY=your_sarvam_api_key_here

# Groq (Whisper Speech-to-Text)
GROQ_API_KEY=your_groq_api_key_here

# Spotify
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# Picovoice (Wake Word Engine)
PICOVOICE_ACCESS_KEY=your_picovoice_key_here

# Alexa Webhook Bridge
ALEXA_WEBHOOK_URL=your_ngrok_url_here
FRIDAY_WEBHOOK_SECRET=your_webhook_secret_here

# OpenCode Integration (Multi-Agent Sub-Agents)
# Set OPENCODE_ZEN_API_KEY to use the Zen API (cloud, big-pickle model) instead of local opencode serve
OPENCODE_ZEN_API_KEY=your_opencode_zen_key_here
OPENCODE_ZEN_MODEL=opencode/big-pickle

# NVIDIA NIM Vision (Free vision model for object detection / scene understanding)
NVIDIA_NIM_VISION_MODEL=microsoft/Florence-2-large

# ─── OSINT API KEYS ──────────────────────────────────────────────

# Shodan (Device Search) — free: 100 results/month, get key at https://account.shodan.io
SHODAN_API_KEY=your_shodan_api_key_here

# Censys (Host/Certificate Search) — free: 250 queries/month, get at https://search.censys.io/account/api
CENSYS_API_ID=your_censys_api_id_here
CENSYS_API_SECRET=your_censys_api_secret_here

# VirusTotal (File/URL/Domain Reputation) — free: 500/day, 4 req/min
VIRUSTOTAL_API_KEY=your_virustotal_api_key_here

# URLScan.io (URL Scanner) — free: 50/month public, 250/month unlisted
URLSCAN_API_KEY=your_urlscan_api_key_here

# AbuseIPDB (IP Reputation) — free: 1000 checks/day
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here

# IPinfo (Geolocation/ASN) — free: 50K requests/month
IPINFO_API_KEY=your_ipinfo_api_key_here

# GitHub Personal Access Token — free: 5000 req/hr authenticated
GITHUB_TOKEN=your_github_token_here

# GitLab Personal Access Token — free: 2000 req/min
GITLAB_TOKEN=your_gitlab_token_here

# Telegram API Credentials — free, get at https://my.telegram.org/apps
TELEGRAM_API_ID=your_telegram_api_id
TELEGRAM_API_HASH=your_telegram_api_hash

# Reddit API — free, create app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret

# Twitter/X API v2 — free tier: 500K tweets/month (requires Developer Account)
TWITTER_BEARER_TOKEN=your_twitter_bearer_token
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret

# Instagram API — free, uses instagrapi library
INSTAGRAM_USER=your_instagram_username
INSTAGRAM_PASS=your_instagram_password

# Hunter.io (Email Domain Search) — free: 25 searches/month
HUNTER_API_KEY=your_hunter_api_key_here

# Clearbit (Company/Person Enrichment) — free tier limited
CLEARBIT_API_KEY=your_clearbit_api_key_here

# SecurityTrails (DNS/WHOIS History) — free: 50 queries/month
SECURITYTRAILS_API_KEY=your_securitytrails_api_key_here

# AlienVault OTX (Threat Intelligence) — free
OTX_API_KEY=your_otx_api_key_here

# Have I Been Pwned API — free, no key needed for v3
# Dehashed (Breach Data) — paid only ($3.99+/mo)
DEHASHED_API_KEY=your_dehashed_api_key
DEHASHED_EMAIL=your_dehashed_email

# IntelX (Intelligence X) — paid
INTELX_API_KEY=your_intelx_api_key_here

# LeakCheck.io — free/public endpoint available
LEAKCHECK_API_KEY=your_leakcheck_key_here

# Flickr API
FLICKR_API_KEY=your_flickr_api_key_here

# Discogs API
DISCOGS_TOKEN=your_discogs_token_here
