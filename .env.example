# ─── FRIDAY API KEYS ─────────────────────────────────────────────
# Keep this file secret. Never commit it to git.
# Copy to .env and fill in your keys.

# Google Gemini (Brain & Vision)
GOOGLE_API_KEY=your_google_api_key_here
GCP_PROJECT=your_gcp_project
GCP_LOCATION=us-central1

# NVIDIA NIM (LLM + Vision)
NVIDIA_NIM_API_KEY=your_nvidia_nim_key_here

# Sarvam AI (Text-to-Speech)
SARVAM_API_KEY=your_sarvam_api_key_here

# Groq (Whisper Speech-to-Text)
GROQ_API_KEY=your_groq_api_key_here

# Spotify
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8888/callback

# Picovoice (Wake Word Engine)
PICOVOICE_ACCESS_KEY=your_picovoice_key_here

# Alexa Webhook Bridge
ALEXA_WEBHOOK_URL=your_ngrok_url_here
FRIDAY_WEBHOOK_SECRET=your_webhook_secret_here

# OpenCode Integration (Multi-Agent Sub-Agents)
# Set OPENCODE_ZEN_API_KEY to use the Zen API (cloud, big-pickle model) instead of local opencode serve
OPENCODE_ZEN_API_KEY=your_opencode_zen_key_here
OPENCODE_ZEN_MODEL=opencode/big-pickle

# NVIDIA NIM Vision (Free vision model for object detection / scene understanding)
NVIDIA_NIM_VISION_MODEL=microsoft/Florence-2-large
